# development | production | test
APP_ENV=development

# 本地默认用 SQLite 即可跑通全流程；生产切换为 PostgreSQL 异步驱动
DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trpg

# 是否开启 /docs /redoc /openapi.json，本地开发默认开启
ENABLE_DOCS=true

LOG_LEVEL=INFO

# AI 主持；真实 Key 只写入被 Git 忽略的 .env，不要写入本示例文件
KEEPER_PROVIDER=fake
# KEEPER_PROVIDER=deepseek
# KEEPER_MODEL=deepseek-chat
# KEEPER_BASE_URL=https://api.deepseek.com
# KEEPER_API_KEY=请仅在本地.env中填写真实Key
# 单个主持阶段超过该秒数即终止等待，默认 30 秒
KEEPER_TIMEOUT_SECONDS=30

# JSON 数组格式
CORS_ORIGINS=["http://localhost:9877"]
